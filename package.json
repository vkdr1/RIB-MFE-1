{
  "name": "mfe-pro2",
  "version": "1.0.0",
  "description": "Angular 21 Native Federation Workspace",
  "scripts": {
    "ng": "node node_modules/@angular/cli/bin/ng.js",
    "start": "node node_modules/@angular/cli/bin/ng.js serve",
    "start:shell": "node node_modules/@angular/cli/bin/ng.js serve shell --port 4200",
    "start:login": "node node_modules/@angular/cli/bin/ng.js serve login --port 4201",
    "start:user-dashboard": "node node_modules/@angular/cli/bin/ng.js serve user-dashboard --port 4202",
    "build": "node node_modules/@angular/cli/bin/ng.js build",
    "build:shell": "node node_modules/@angular/cli/bin/ng.js build shell --configuration production",
    "build:login": "node node_modules/@angular/cli/bin/ng.js build login --configuration production",
    "build:user-dashboard": "node node_modules/@angular/cli/bin/ng.js build user-dashboard --configuration production",
    "build:shared-ui": "node node_modules/@angular/cli/bin/ng.js build shared-ui",
    "build:all": "npm run build:shared-ui && npm run build:login && npm run build:user-dashboard && npm run build:shell",
    "watch": "node node_modules/@angular/cli/bin/ng.js build --watch --configuration development",
    "test": "node node_modules/@angular/cli/bin/ng.js test",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:prod": "docker-compose up --build",
    "docker:prod:down": "docker-compose down"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@primeuix/themes": "^2.0.3",
    "@softarc/native-federation-node": "^3.3.4",
    "@types/lodash": "^4.17.23",
    "@types/luxon": "^3.7.1",
    "chart.js": "^4.5.1",
    "es-module-shims": "^1.5.12",
    "lodash": "^4.17.23",
    "luxon": "^3.7.2",
    "primeclt": "^0.1.5",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.1.1",
    "@angular-devkit/build-angular": "^21.0.4",
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@tailwindcss/postcss": "^4.1.18",
    "angular-eslint": "21.2.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vitest": "^4.0.8"
  }
}
